{
  "page": {
    "id": "home",
    "title": "首页",
    "refreshable": true,
    "minClientVersion": 1,
    "requiredCapabilities": [
      "toast",
      "open",
      "modal",
      "alert",
      "copy",
      "track",
      "back"
    ]
  },
  "templates": {},
  "card": {
    "log_id": "home",
    "states": [
      {
        "state_id": 0,
        "div": {
          "type": "container",
          "orientation": "vertical",
          "paddings": {
            "left": 20,
            "right": 20,
            "top": 40,
            "bottom": 20
          },
          "items": [
            {
              "type": "text",
              "text": "DivKit 本地联调 by hans",
              "font_size": 24,
              "font_weight": "bold",
              "text_color": "#111111"
            },
            {
              "type": "text",
              "text": "修改 home.json 后，下拉刷新即可看到更新。",
              "font_size": 16,
              "text_color": "#666666",
              "margins": {
                "top": 12
              }
            },
            {
              "type": "text",
              "text": "Toast",
              "font_size": 18,
              "text_color": "#FFFFFF",
              "background": [
                {
                  "type": "solid",
                  "color": "#1677FF"
                }
              ],
              "border": {
                "corner_radius": 8
              },
              "paddings": {
                "left": 16,
                "right": 16,
                "top": 10,
                "bottom": 10
              },
              "margins": {
                "top": 24
              },
              "actions": [
                {
                  "log_id": "toast",
                  "typed": {
                    "type": "custom"
                  },
                  "payload": {
                    "action": "toast",
                    "text": "Hello DivKit"
                  }
                }
              ]
            },
            {
              "type": "text",
              "text": "打开详情页",
              "font_size": 18,
              "text_color": "#FFFFFF",
              "background": [
                {
                  "type": "solid",
                  "color": "#16A34A"
                }
              ],
              "border": {
                "corner_radius": 8
              },
              "paddings": {
                "left": 16,
                "right": 16,
                "top": 10,
                "bottom": 10
              },
              "margins": {
                "top": 12
              },
              "actions": [
                {
                  "log_id": "open_detail",
                  "typed": {
                    "type": "custom"
                  },
                  "payload": {
                    "action": "open",
                    "path": "detail",
                    "title": "详情"
                  }
                }
              ]
            },
            {
              "type": "text",
              "text": "弹出 Modal",
              "font_size": 18,
              "text_color": "#FFFFFF",
              "background": [
                {
                  "type": "solid",
                  "color": "#7C3AED"
                }
              ],
              "border": {
                "corner_radius": 8
              },
              "paddings": {
                "left": 16,
                "right": 16,
                "top": 10,
                "bottom": 10
              },
              "margins": {
                "top": 12
              },
              "actions": [
                {
                  "log_id": "open_modal",
                  "typed": {
                    "type": "custom"
                  },
                  "payload": {
                    "action": "modal",
                    "path": "dialog",
                    "title": "弹窗",
                    "style": "sheet"
                  }
                }
              ]
            },
            {
              "type": "text",
              "text": "更多原生能力",
              "font_size": 18,
              "text_color": "#FFFFFF",
              "background": [
                {
                  "type": "solid",
                  "color": "#0F766E"
                }
              ],
              "border": {
                "corner_radius": 8
              },
              "paddings": {
                "left": 16,
                "right": 16,
                "top": 10,
                "bottom": 10
              },
              "margins": {
                "top": 12
              },
              "actions": [
                {
                  "log_id": "native_alert",
                  "typed": {
                    "type": "custom"
                  },
                  "payload": {
                    "action": "alert",
                    "title": "提示",
                    "message": "这是原生弹窗"
                  }
                },
                {
                  "log_id": "copy_text",
                  "typed": {
                    "type": "copy_to_clipboard",
                    "content": {
                      "type": "text",
                      "value": "Copied from DivKit"
                    }
                  }
                },
                {
                  "log_id": "track_event",
                  "typed": {
                    "type": "custom"
                  },
                  "payload": {
                    "action": "track",
                    "name": "home_more_native"
                  }
                }
              ]
            }
          ]
        }
      }
    ]
  }
}
